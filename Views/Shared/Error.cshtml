@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="py-5" style="padding-top: 100px !important; min-height: 60vh; display: flex; align-items: center;">
    <div class="container text-center">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <i class="bi bi-exclamation-triangle" style="font-size: 5rem; color: var(--primary-color);"></i>
                <h1 class="mt-4 mb-3" style="color: var(--text-primary);">Oops! Something went wrong</h1>
                <p class="text-secondary mb-4">An error occurred while processing your request.</p>
                
                @if (Model.ShowRequestId)
                {
                    <p class="text-muted">
                        <strong>Request ID:</strong> <code>@Model.RequestId</code>
                    </p>
                }
                
                <a href="/" class="btn btn-primary mt-3"><i class="bi bi-house me-2"></i>Back to Home</a>
            </div>
        </div>
    </div>
</section>
