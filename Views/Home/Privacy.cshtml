@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="py-5" style="padding-top: 100px !important;">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <h1 class="section-title mb-4">@ViewData["Title"]</h1>
                <div class="timeline-content p-4">
                    <p class="text-secondary">This privacy policy outlines how your personal information is collected, used, and protected when you visit this website.</p>
                    
                    <h4 class="mt-4 mb-3" style="color: var(--primary-color);">Information Collection</h4>
                    <p class="text-secondary">We do not collect any personal information unless you voluntarily provide it through the contact form.</p>
                    
                    <h4 class="mt-4 mb-3" style="color: var(--primary-color);">Use of Information</h4>
                    <p class="text-secondary">Any information you provide is used solely to respond to your inquiries.</p>
                    
                    <h4 class="mt-4 mb-3" style="color: var(--primary-color);">Data Protection</h4>
                    <p class="text-secondary">We implement appropriate security measures to protect your personal information.</p>
                    
                    <h4 class="mt-4 mb-3" style="color: var(--primary-color);">Contact</h4>
                    <p class="text-secondary">If you have any questions about this privacy policy, please contact us at tinotendanyakatsarii2@gmail.com</p>
                </div>
            </div>
        </div>
    </div>
</section>
